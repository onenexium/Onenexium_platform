# Local development — copy to .env.local (never commit .env.local)
# Next.js loads .env.local for `npm run dev`

NODE_ENV=development

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=OneNexium (Dev)

# Drizzle ORM + Postgres — local: set DATABASE_URL then `npm run db:push` (or `db:migrate`).
# EC2 + Secrets Manager: leave DATABASE_URL unset at runtime; use `npm run db:push:sm` / `db:migrate:sm`.
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/onenexium_dev?schema=public"

# EC2 — load RDS + auth from SM at boot (see instrumentation.ts)
# AWS_REGION=ap-south-1
# AWS_SECRETS_PREFIX=onenexium/platform

# Optional — email (Resend)
# RESEND_API_KEY=

# Optional — AWS (default credential chain: ~/.aws, env keys, or EC2 role)
# AWS_REGION=ap-south-1
# AWS_SECRETS_PREFIX=onenexium/platform
# AWS_S3_BUCKET=onenexium-storage-268054298224
# AWS_SES_FROM=noreply@onenexium.com
# AWS_SES_CONFIGURATION_SET=onenexium-transactional
# WAITLIST_NOTIFY_TO=you@example.com

# Auth.js (Google) — required for /app and /admin
# AUTH_SECRET=generate-with-openssl-rand-base64-32
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# Optional: canonical URL for OAuth (defaults inferred when trustHost is on)
# AUTH_URL=http://localhost:3000

# Optional — comma-separated Google emails allowed to open /admin (omit = any signed-in user)
# AUTH_ADMIN_EMAILS=you@onenexium.com

# Secrets Manager bootstrap (Node server only) — omit locally if you use .env only
# AWS_SECRETS_PREFIX=onenexium/platform
# Optional JSON secret merged first: object keys become env vars (see server/secrets/bootstrap-runtime-env.ts)
# AWS_SECRETS_JSON_ID=app-runtime
# AWS_SECRETS_BOOTSTRAP=0

# Optional — waitlist GET protection + legacy header gate if you still use it
# ADMIN_API_KEY=long-random-string

# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
