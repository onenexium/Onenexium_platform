# Production — reference only; on EC2 these come from AWS Secrets Manager + start script
# (see Onenexium_aws_setup/Platform_deployement.md). Do not put real secrets here.

NODE_ENV=production

NEXT_PUBLIC_SITE_URL=https://onenexium.com
NEXT_PUBLIC_APP_NAME=OneNexium

# On EC2: IAM role + Secrets Manager (instrumentation hydrates process.env on boot).
# Mirror secret names in docs/AWS_CREDENTIALS.md (NEXTAUTH_SECRET → AUTH_SECRET, GOOGLE_* → AUTH_GOOGLE_*).
# AWS_REGION=ap-south-1
# AWS_SECRETS_PREFIX=onenexium/platform
# Optional bundle: JSON object in one secret
# AWS_SECRETS_JSON_ID=onenexium/platform/app-runtime

# Auth.js — can be loaded entirely from SM via prefix above
# AUTH_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_URL=https://onenexium.com
# AUTH_ADMIN_EMAILS=ops@onenexium.com

# AWS_SES_FROM=noreply@onenexium.com
# AWS_SES_CONFIGURATION_SET=onenexium-transactional
# WAITLIST_NOTIFY_TO=ops@onenexium.com
# ADMIN_API_KEY=

# RESEND_API_KEY=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
